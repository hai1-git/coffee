<section class="coffee-hero">
    <div id="blog-carousel" class="carousel slide overlay-bottom" data-ride="carousel">
        <div class="carousel-inner">
            <div class="carousel-item active">
                <img class="w-100" src="~/img/carousel-1.jpg" alt="Coffee beans and cup">
                <div class="carousel-caption d-flex flex-column align-items-center justify-content-center">
                    <span class="coffee-hero-kicker">KOPPEE SIGNATURE EXPERIENCE</span>
                    <h2 class="text-primary font-weight-medium m-0">Huong vi duoc cham chut moi ngay</h2>
                    <h1 class="display-1 text-white m-0">COFFEE</h1>
                    <p class="coffee-hero-copy">
                        Tu caphe dam vi den latte nhe nhang, moi ly deu duoc sap xep de ban xem, chon va dat mon de dang hon.
                    </p>
                    <div class="coffee-hero-actions">
                        <a asp-controller="Products" asp-action="Index" class="btn coffee-hero-primary">Xem thuc don</a>
                        <a asp-controller="Home" asp-action="Reservation" class="btn coffee-hero-secondary">Dat ban ngay</a>
                    </div>
                </div>
            </div>
            <div class="carousel-item">
                <img class="w-100" src="~/img/carousel-2.jpg" alt="Coffee served on table">
                <div class="carousel-caption d-flex flex-column align-items-center justify-content-center">
                    <span class="coffee-hero-kicker">SMOOTH ORDERING JOURNEY</span>
                    <h2 class="text-primary font-weight-medium m-0">Chuyen trang muot hon, dat mon nhanh hon</h2>
                    <h1 class="display-1 text-white m-0">KOPPEE</h1>
                    <p class="coffee-hero-copy">
                        Header duoc giu co dinh de ban luon thay loi di chuyen giua trang chu, thuc don, gio hang va don hang.
                    </p>
                    <div class="coffee-hero-actions">
                        <a asp-controller="Home" asp-action="About" class="btn coffee-hero-primary">Tim hieu quan</a>
                        <a asp-controller="Home" asp-action="Contact" class="btn coffee-hero-secondary">Lien he</a>
                    </div>
                </div>
            </div>
        </div>

        <a class="carousel-control-prev" href="#blog-carousel" data-slide="prev">
            <span class="carousel-control-prev-icon"></span>
        </a>
        <a class="carousel-control-next" href="#blog-carousel" data-slide="next">
            <span class="carousel-control-next-icon"></span>
        </a>
    </div>
</section>
