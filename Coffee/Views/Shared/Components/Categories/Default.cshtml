@model IEnumerable<Coffee.DTO.CategoryDTO>
@using System
@using System.Linq
@{
    ViewData["Title"] = "Default";
    var selectedCategory = ViewContext.HttpContext.Request.Query["loai"].ToString();
}

<div class="category-wrapper">
    <div class="category-header">
        <div>
            <span class="category-kicker">Coffee menu</span>
            <h4 class="category-title">Danh Mục</h4>
            <p class="category-intro">Chọn nhanh nhóm món bạn muốn để lọc menu gọn hơn, dễ tìm hơn.</p>
        </div>
        <span class="category-badge">@Model.Count()</span>
    </div>

    <div class="category-summary">
        <span><i class="fas fa-layer-group mr-2"></i>@Model.Count() nhóm đồ uống</span>
        <span><i class="fas fa-fire mr-2"></i>Hot item được đẩy lên đầu</span>
    </div>

    <a asp-controller="Products"
       asp-action="Index"
       class="category-link category-link-all @(string.IsNullOrWhiteSpace(selectedCategory) ? "is-active" : null)">
        <span class="category-icon-shell">
            <i class="fas fa-th-large"></i>
        </span>

        <span class="category-copy">
            <span class="name">Tat ca mon</span>
            <small>Xem toan bo thuc don cua quan</small>
        </span>

        <span class="arrow">
            <i class="fas fa-chevron-right"></i>
        </span>
    </a>

    <div class="category-list-shell">
        <ul class="category-list">
            @foreach (var c in Model)
            {
                var isActive = string.Equals(selectedCategory, c.Id.ToString(), StringComparison.OrdinalIgnoreCase);
                var description = string.IsNullOrWhiteSpace(c.Description)
                    ? "Nhom do uong duoc goi nhieu"
                    : c.Description;

                <li class="category-item">
                    <a asp-controller="Products"
                       asp-action="Index"
                       asp-route-loai="@c.Id"
                       class="category-link @(isActive ? "is-active" : null)">
                        <span class="category-icon-shell">
                            <i class="fas fa-mug-hot"></i>
                        </span>

                        <span class="category-copy">
                            <span class="name">@c.Name</span>
                            <small>@description</small>
                        </span>

                        <span class="arrow">
                            <i class="fas fa-chevron-right"></i>
                        </span>
                    </a>
                </li>
            }
        </ul>
    </div>
</div>
