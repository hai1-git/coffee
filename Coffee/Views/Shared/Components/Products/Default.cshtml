@model IEnumerable<Coffee.DTO.ProductDTO>

<div class="container py-5">

    <div class="@(Model.Count() == 1
                 ? "d-flex justify-content-center"
                 : "row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-5")">

        @foreach (var item in Model)
        {
            <div class="col">

                <div class="card h-100 border-0 shadow-sm product-card">

                    <!-- IMAGE -->
                    <div class="position-relative overflow-hidden rounded-top-4" style="height:230px;">

                        <img src="@item.ImageUrl"
                             class="card-img p-2 rounded-5 h-100 w-100 object-fit-cover transition-img"
                             alt="@item.ProductName">

                        <!-- OVERLAY -->
                        <div class="product-overlay d-flex align-items-center justify-content-center">
                            <a asp-controller="Products"
                               asp-action="Details"
                               asp-route-id="@item.Id"
                               class="product-quick-view">
                                <i class="fas fa-eye mr-2"></i>
                                <span>Xem nhanh</span>
                            </a>
                        </div>
                    </div>

                    <!-- BODY -->
                    <div class="card-body d-flex flex-column p-4">

                        <h6 class="fw-bold text-dark mb-2 fs-5">
                            @item.ProductName
                        </h6>

                        <p class="text-muted small flex-grow-1 mb-3 lh-sm">
                            @item.Description
                        </p>

                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="fs-5 fw-bold text-coffee">
                                @item.Price.ToString("N0") đ
                            </span>
                            <span class="badge bg-light text-success border border-success-subtle">
                                Còn hàng
                            </span>
                        </div>

                        <!-- QTY -->
                        <div class="input-group mb-3 product-quantity-group">
                            <button type="button" class="btn btn-minus product-qty-btn">-</button>

                            <input type="text"
                                   class="form-control text-center quantity-input"
                                   name="quantity"
                                   form="buy-now-featured-@item.Id"
                                   value="1"
                                   inputmode="numeric">

                            <button type="button" class="btn btn-plus product-qty-btn">+</button>
                        </div>

                        <!-- BUTTON -->
                        <div class="d-grid gap-2">

                            <button class="btn btn-add-cart product-action product-action-primary"
                                    data-productid="@item.Id">
                                <i class="fas fa-cart-plus mr-2"></i>
                                <span>Them vao gio</span>
                            </button>

                            <form id="buy-now-featured-@item.Id"
                                  asp-controller="Checkout"
                                  asp-action="BuyNow"
                                  method="get"
                                  class="m-0">
                                <input type="hidden" name="productId" value="@item.Id" />
                                <button type="submit" class="btn product-action product-action-accent w-100">
                                    <i class="fas fa-bolt mr-2"></i>
                                    <span>Thanh toan ngay</span>
                                </button>
                            </form>

                        </div>

                    </div>
                </div>

            </div>
        }

    </div>

</div>

