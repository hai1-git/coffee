@{
    Layout = "_ProductsCoffee";
}

<div class="container py-4">

    <!-- HEADER -->
    <div class="d-flex align-items-center gap-3 mb-4">
        <a asp-controller="Products" asp-action="Index"
           class="btn btn-outline-dark">
            ← Back
        </a>

        <h2 class="mb-0">⚙️ Trang quản trị</h2>
    </div>

    <!-- MENU -->
    <div class="list-group shadow-sm">

        <a asp-controller="Categories" asp-action="Index"
           class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
            <span>📂 Quản lý Category</span>
            <span>→</span>
        </a>

        <a asp-controller="AdminProducts" asp-action="Index"
           class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
            <span>☕ Quản lý Product</span>
            <span>→</span>
        </a>

    </div>

</div>