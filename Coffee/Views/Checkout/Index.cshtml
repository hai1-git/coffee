@model Coffee.ViewModel.CheckoutViewModel
@{
    Layout = "_ProductsCoffee";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Checkout/checkout.css" />
}

<div class="checkout-page container py-4 py-lg-5">
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="checkout-section-title">
                <h4 class="mb-0">San pham da chon</h4>
                <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-dark btn-sm">Quay lai gio hang</a>
            </div>

            <div class="checkout-info-card mb-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0">Thong tin nhan hang</h5>
                    <a asp-controller="Auth" asp-action="Profile" class="btn btn-outline-secondary btn-sm">
                        Cap nhat ho so
                    </a>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="ReceiverName" class="form-label">Ten nguoi nhan</label>
                        <input asp-for="ReceiverName" class="form-control" placeholder="Nhap ten nguoi nhan" form="checkout-form" />
                        <span asp-validation-for="ReceiverName" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="ReceiverPhone" class="form-label">So dien thoai</label>
                        <input asp-for="ReceiverPhone" class="form-control" placeholder="Nhap so dien thoai shipper lien he" form="checkout-form" />
                        <span asp-validation-for="ReceiverPhone" class="text-danger small"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="ShippingAddress" class="form-label">Dia chi giao hang</label>
                        <textarea asp-for="ShippingAddress"
                                  class="form-control"
                                  rows="4"
                                  placeholder="So nha, ten duong, phuong/xa, quan/huyen, tinh/thanh pho"
                                  form="checkout-form"></textarea>
                        <span asp-validation-for="ShippingAddress" class="text-danger small"></span>
                        <div class="small text-muted mt-2">
                            Dien dia chi cang chi tiet thi shipper giao hang cang chuan, giong cach dat tren TikTok Shop.
                        </div>
                    </div>
                </div>
            </div>

            <section class="checkout-products-panel">
                <div class="checkout-products-panel-header">
                    <div>
                        <h5 class="mb-1">Danh sach san pham</h5>
                        <p class="text-muted mb-0">Neu don co nhieu mon, ban cuon ben trong khung nay de phan nhap thong tin va thanh toan van gon o tren.</p>
                    </div>

                    <span class="checkout-chip">@Model.Items.Count san pham</span>
                </div>

                <div class="checkout-products-scroll">
                    <div class="checkout-products-list">
                        @foreach (var item in Model.Items)
                        {
                            <article class="checkout-product-card">
                                <div class="checkout-product-main">
                                    <div class="checkout-product-name">@item.ProductName</div>
                                    <div class="checkout-product-meta">Don gia: @item.Price.ToString("N0") đ</div>
                                </div>

                                <div class="checkout-product-qty">x @item.Quantity</div>
                                <div class="checkout-product-subtotal">@item.SubTotal.ToString("N0") đ</div>
                            </article>
                        }
                    </div>
                </div>
            </section>
        </div>

        <div class="col-lg-4">
            <div class="checkout-summary-card">
                <h4 class="mb-3">Thanh toan COD</h4>

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="checkout-payment-note p-3 mb-3">
                    <div class="fw-bold text-dark mb-2">Thanh toan khi nhan hang</div>
                    <div class="small text-muted">
                        Shop se ship den dia chi ban vua nhap. Khi nhan duoc hang, ban moi thanh toan cho shipper.
                    </div>
                </div>

                <form id="checkout-form" asp-action="Index" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="SelectedItemsJson" type="hidden" />
                    <input asp-for="PaymentMethod" type="hidden" value="COD" />

                    <div class="d-flex justify-content-between mb-2">
                        <span>Tong tien</span>
                        <strong class="text-danger">@Model.Total.ToString("N0")</strong>
                    </div>

                    <button type="submit" class="btn btn-danger w-100 mt-3">
                        Dat hang COD
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
