@model IEnumerable<Coffee.DTO.ProductDTO>
@{
    ViewData["Title"] = "Index";
    Layout = "_ProductsCoffee";
}

<div class="product-layout mt-4">
    <div class="sidebar">
        <div class="sidebar-stack">
            <section class="sidebar-panel">
                @await Component.InvokeAsync("Categories")
            </section>

            <section class="sidebar-panel sidebar-panel-spotlight">
                <div class="sidebar-spotlight-head">
                    <span class="sidebar-kicker">Best seller</span>
                    <h2>San pham cuc hot</h2>
                    <p>Mon dang duoc khach quay lai goi nhieu nhat trong thoi gian gan day.</p>
                </div>

                @await Component.InvokeAsync("Products", new { count = 1 })
            </section>
        </div>
    </div>

    @await Html.PartialAsync("_Products", Model)

</div>
@section Scripts {
    <script src="~/js/Products/Products.js" asp-append-version="true"></script>
}
