@model Coffee.DTO.ProductDTO

@{
    ViewData["Title"] = "Chi tiet san pham";
    Layout = "_ProductsCoffee";
    var productDescription = string.IsNullOrWhiteSpace(Model.Description)
        ? "Mon duoc trinh bay gon gang de ban chon nhanh, dat mon de va theo doi don hang thoai mai hon tren moi thiet bi."
        : Model.Description.Trim();
    var productImage = string.IsNullOrWhiteSpace(Model.ImageUrl)
        ? Url.Content("~/img/menu-1.jpg")
        : Model.ImageUrl;
}

@section Styles {
    <link rel="stylesheet" href="~/css/Products/product-details.css" />
}

<section class="product-detail-page">
    <div class="container product-detail-container py-4 py-lg-5">
        <div class="product-detail-shell">
            <div class="product-detail-visual">
                <div class="product-detail-image-card">
                    <div class="product-detail-image-wrap">
                        <img src="@productImage" alt="@Model.ProductName" />
                    </div>

                    <div class="product-detail-image-footer">
                        <span class="product-detail-chip">
                            <i class="fas fa-mug-hot"></i>
                            Phuc vu tai quan
                        </span>
                        <span class="product-detail-chip product-detail-chip-soft">
                            <i class="fas fa-bolt"></i>
                            Dat mon nhanh gon
                        </span>
                    </div>
                </div>
            </div>

            <div class="product-detail-content">
                <div class="product-detail-card">
                    <div class="product-detail-heading">
                        <span class="product-detail-eyebrow">Chi tiet san pham</span>
                        <h1>@Model.ProductName</h1>
                        <p>@productDescription</p>
                    </div>

                    <div class="product-detail-price-row">
                        <div>
                            <div class="product-detail-label">Gia ban</div>
                            <div class="product-detail-price">@Model.Price.ToString("N0") đ</div>
                        </div>

                        <div class="product-detail-stock">
                            <i class="fas fa-check-circle"></i>
                            <span>San sang phuc vu</span>
                        </div>
                    </div>

                    <div class="product-detail-purchase">
                        <div class="product-detail-purchase-head">
                            <div>
                                <h5>Chon so luong</h5>
                                <p>Dieu chinh so luong truoc khi them vao gio hoac dat ngay.</p>
                            </div>
                        </div>

                        <div class="input-group product-detail-quantity product-quantity-group">
                            <button type="button" class="btn btn-minus product-qty-btn">-</button>

                            <input type="text"
                                   class="form-control text-center quantity-input"
                                   name="quantity"
                                   form="buy-now-detail-@Model.Id"
                                   value="1">

                            <button type="button" class="btn btn-plus product-qty-btn">+</button>
                        </div>

                        <div class="product-detail-actions">
                            <button class="btn btn-lg btn-add-cart product-detail-action product-action product-action-primary"
                                    data-productid="@Model.Id">
                                <i class="fas fa-shopping-cart mr-2"></i>
                                Them vao gio
                            </button>

                            <form id="buy-now-detail-@Model.Id"
                                  asp-controller="Checkout"
                                  asp-action="BuyNow"
                                  method="get"
                                  class="m-0">
                                <input type="hidden" name="productId" value="@Model.Id" />
                                <button type="submit" class="btn btn-lg w-100 product-detail-action product-action product-action-accent">
                                    <i class="fas fa-credit-card mr-2"></i>
                                    Thanh toan ngay
                                </button>
                            </form>
                        </div>
                    </div>

                    <a asp-controller="Products"
                       asp-action="Index"
                       class="product-detail-backlink">
                        <i class="fas fa-arrow-left mr-2"></i>
                        Quay lai danh sach san pham
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script src="~/js/Products/Products.js" asp-append-version="true"></script>
}
