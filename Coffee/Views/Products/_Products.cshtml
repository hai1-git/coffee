@model IEnumerable<Coffee.DTO.ProductDTO>

<div class="container py-5">

    <!-- TITLE -->
    <div class="text-center mb-5">
        <h2 class="fw-bold">☕ Coffee Store</h2>
        <p class="text-muted">Chọn món bạn thích và thưởng thức ngay</p>
    </div>

    <!-- GRID -->
    <div class="row g-4 products-grid">

        @foreach (var item in Model)
        {
            <div class="col-lg-3 col-md-4 col-sm-6">

                <div class="card product-card h-100 border-0 shadow-sm">

                    <!-- IMAGE -->
                    <div class="product-img-wrapper">
                        <img src="@item.ImageUrl"
                             alt="@item.ProductName">

                        <div class="product-overlay">
                            <a asp-controller="Products"
                               asp-action="Details"
                               asp-route-id="@item.Id"
                               class="product-quick-view">
                                <i class="fas fa-eye mr-2"></i>
                                <span>Xem nhanh</span>
                            </a>
                        </div>
                    </div>

                    <!-- BODY -->
                    <div class="card-body d-flex flex-column">

                        <h6 class="fw-bold text-dark mb-2">
                            @item.ProductName
                        </h6>

                        <p class="text-muted small flex-grow-1">
                            @item.Description
                        </p>

                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="price">
                                @item.Price.ToString("N0") đ
                            </span>
                            <span class="badge bg-success">Còn hàng</span>
                        </div>

                        <!-- QTY -->
                        <div class="input-group mb-3 product-quantity-group">
                            <button type="button" class="btn btn-minus product-qty-btn">-</button>

                            <input type="text"
                                   class="form-control text-center quantity-input"
                                   name="quantity"
                                   form="buy-now-product-@item.Id"
                                   value="1"
                                   inputmode="numeric">

                            <button type="button" class="btn btn-plus product-qty-btn">+</button>
                        </div>

                        <!-- BUTTON -->
                        <div class="d-grid gap-2">

                            <button class="btn btn-add-cart product-action product-action-primary"
                                    data-productid="@item.Id">
                                <i class="fas fa-cart-plus mr-2"></i>
                                <span>Them vao gio</span>
                            </button>

                            <form id="buy-now-product-@item.Id"
                                  asp-controller="Checkout"
                                  asp-action="BuyNow"
                                  method="get"
                                  class="m-0">
                                <input type="hidden" name="productId" value="@item.Id" />
                                <button type="submit" class="btn product-action product-action-accent w-100">
                                    <i class="fas fa-bolt mr-2"></i>
                                    <span>Thanh toan ngay</span>
                                </button>
                            </form>

                            <a asp-controller="Products"
                               asp-action="Details"
                               asp-route-id="@item.Id"
                               class="btn product-action product-action-secondary">
                                <i class="fas fa-arrow-right mr-2"></i>
                                <span>Xem chi tiet</span>
                            </a>

                        </div>

                    </div>

                </div>

            </div>
        }

    </div>

    <!-- ========================= -->
    <!-- 🔥 PAGINATION XỊN -->
    <!-- ========================= -->
    @{
        int current = ViewBag.CurrentPage ?? 1;
        int total = ViewBag.TotalPages ?? 1;
        int maxDisplay = 4;

        int start = Math.Max(1, current - 1);
        int end = start + maxDisplay - 1;

        if (end > total)
        {
            end = total;
            start = Math.Max(1, end - maxDisplay + 1);
        }
    }

    <div class="d-flex justify-content-center mt-5">
        <nav>
            <ul class="pagination shadow-sm">

                <!-- PREV -->
                <li class="page-item @(current == 1 ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@(current - 1)"
                       asp-route-loai="@ViewBag.Loai">
                        «
                    </a>
                </li>

                <!-- PAGE -->
                @for (int i = start; i <= end; i++)
                {
                    <li class="page-item @(i == current ? "active" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@i"
                           asp-route-loai="@ViewBag.Loai">
                            @i
                        </a>
                    </li>
                }

                <!-- NEXT -->
                <li class="page-item @(current == total ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@(current + 1)"
                       asp-route-loai="@ViewBag.Loai">
                        »
                    </a>
                </li>

            </ul>
        </nav>
    </div>

</div>
