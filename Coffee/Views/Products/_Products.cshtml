@model IEnumerable<Coffee.DTO.ProductDTO>

<div class="container py-5">

    <!-- TITLE -->
    <div class="text-center mb-5">
        <h2 class="fw-bold">☕ Coffee Store</h2>
        <p class="text-muted">Chọn món bạn thích và thưởng thức ngay</p>
    </div>

    <!-- GRID -->
    <div class="row g-4">

        @foreach (var item in Model)
        {
            <div class="col-lg-3 col-md-4 col-sm-6">

                <div class="card product-card h-100 border-0 shadow-sm">

                    <!-- IMAGE -->
                    <div class="product-img-wrapper">
                        <img src="@item.ImageUrl"
                             alt="@item.ProductName">

                        <div class="product-overlay">
                            <a asp-controller="Products"
                               asp-action="Details"
                               asp-route-id="@item.Id"
                               class="btn btn-light btn-sm">
                                👁 Xem nhanh
                            </a>
                        </div>
                    </div>

                    <!-- BODY -->
                    <div class="card-body d-flex flex-column">

                        <h6 class="fw-bold text-dark mb-2">
                            @item.ProductName
                        </h6>

                        <p class="text-muted small flex-grow-1">
                            @item.Description
                        </p>

                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="price">
                                @item.Price.ToString("N0") đ
                            </span>
                            <span class="badge bg-success">Còn hàng</span>
                        </div>

                        <!-- QTY -->
                        <div class="input-group mb-3">
                            <button class="btn btn-outline-secondary btn-minus">-</button>

                            <input type="text"
                                   class="form-control text-center quantity-input"
                                   value="1">

                            <button class="btn btn-outline-secondary btn-plus">+</button>
                        </div>

                        <!-- BUTTON -->
                        <div class="d-grid gap-2">

                            <button class="btn btn-dark btn-add-cart"
                                    data-productid="@item.Id">
                                🛒 Thêm giỏ hàng
                            </button>

                            <button class="btn btn-warning fw-bold">
                                ⚡ Thanh toán ngay
                            </button>

                            <a asp-controller="Products"
                               asp-action="Details"
                               asp-route-id="@item.Id"
                               class="btn btn-outline-dark">
                                Xem chi tiết
                            </a>

                        </div>

                    </div>

                </div>

            </div>
        }

    </div>

    <!-- ========================= -->
    <!-- 🔥 PAGINATION XỊN -->
    <!-- ========================= -->
    @{
        int current = ViewBag.CurrentPage ?? 1;
        int total = ViewBag.TotalPages ?? 1;
        int maxDisplay = 4;

        int start = Math.Max(1, current - 1);
        int end = start + maxDisplay - 1;

        if (end > total)
        {
            end = total;
            start = Math.Max(1, end - maxDisplay + 1);
        }
    }

    <div class="d-flex justify-content-center mt-5">
        <nav>
            <ul class="pagination shadow-sm">

                <!-- PREV -->
                <li class="page-item @(current == 1 ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@(current - 1)"
                       asp-route-loai="@ViewBag.Loai">
                        «
                    </a>
                </li>

                <!-- PAGE -->
                @for (int i = start; i <= end; i++)
                {
                    <li class="page-item @(i == current ? "active" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@i"
                           asp-route-loai="@ViewBag.Loai">
                            @i
                        </a>
                    </li>
                }

                <!-- NEXT -->
                <li class="page-item @(current == total ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@(current + 1)"
                       asp-route-loai="@ViewBag.Loai">
                        »
                    </a>
                </li>

            </ul>
        </nav>
    </div>

</div>