@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    var title = "Khám phá Koppee";
    var subtitle = "Di chuyển giữa thực đơn, giỏ hàng và đơn hàng trong cùng một khu vực điều hướng gọn gàng.";
    if (string.Equals(currentController, "Products", StringComparison.OrdinalIgnoreCase) && string.Equals(currentAction, "Index", StringComparison.OrdinalIgnoreCase))
    {
        title = "Thực đơn hôm nay";
        subtitle = "Lọc món nhanh hơn, tìm đúng hương vị bạn muốn và chuyển trang không bị mất hướng điều hướng.";
    }
    else if (string.Equals(currentController, "Products", StringComparison.OrdinalIgnoreCase) && string.Equals(currentAction, "Search", StringComparison.OrdinalIgnoreCase))
    {
        title = "Kết quả tìm kiếm";
        subtitle = "So sánh các món ngay trong danh sách và tiếp tục tìm kiếm mà không cần quay lại đầu trang.";
    }
    else if (string.Equals(currentController, "Products", StringComparison.OrdinalIgnoreCase) && string.Equals(currentAction, "Details", StringComparison.OrdinalIgnoreCase))
    {
        title = "Chi tiết sản phẩm";
        subtitle = "Xem nhanh thông tin món, quay lại thực đơn hoặc chuyển sang giỏ hàng để đặt mua.";
    }
    else if (string.Equals(currentController, "Cart", StringComparison.OrdinalIgnoreCase))
    {
        title = "Giỏ hàng";
        subtitle = "Kiểm tra món đã chọn, chỉnh sửa số lượng và đi tiếp sang bước thanh toán thật nhanh.";
    }
    else if (string.Equals(currentController, "Checkout", StringComparison.OrdinalIgnoreCase))
    {
        title = "Thanh toán";
        subtitle = "Thông tin giao hàng và cách thanh toán được gom gọn để bạn xác nhận đơn dễ hơn.";
    }
    else if (string.Equals(currentController, "Orders", StringComparison.OrdinalIgnoreCase))
    {
        title = "Quản lý đơn hàng";
        subtitle = "Theo dõi trạng thái đơn, xem lại chi tiết và quay về menu mua sắm bất kỳ lúc nào.";
    }
    else if (string.Equals(currentController, "Admin", StringComparison.OrdinalIgnoreCase)
        || string.Equals(currentController, "AdminProducts", StringComparison.OrdinalIgnoreCase)
        || string.Equals(currentController, "Categories", StringComparison.OrdinalIgnoreCase))
    {
        title = "Khu vực quản trị";
        subtitle = "Thanh điều hướng được giữ thống nhất để việc quay lại dashboard và menu luôn thuận tay.";
    }
}
<section class="coffee-page-toolbar">
    <div class="coffee-page-toolbar-shell">
        <div class="coffee-toolbar-copy">
            <span class="coffee-toolbar-kicker">KOPPEE NAVIGATION</span>
            <h1>@title</h1>
            <p>@subtitle</p>
        </div>
        <div class="coffee-toolbar-links">
            <a asp-controller="Home" asp-action="Index" class="coffee-toolbar-link">
                <i class="fas fa-home"></i>
                <span>Trang chủ</span>
            </a>
            <a asp-controller="Products" asp-action="Index" class="coffee-toolbar-link">
                <i class="fas fa-mug-hot"></i>
                <span>Thực đơn</span>
            </a>
            <a asp-controller="Cart" asp-action="Index" class="coffee-toolbar-link">
                <i class="fas fa-shopping-cart"></i>
                <span>Giỏ hàng</span>
            </a>
            <a asp-controller="Orders" asp-action="Index" class="coffee-toolbar-link">
                <i class="fas fa-receipt"></i>
                <span>Đơn hàng</span>
            </a>
        </div>
        <div class="coffee-toolbar-search">
            @await Html.PartialAsync("~/Views/Products/_Search.cshtml")
        </div>
    </div>
</section>