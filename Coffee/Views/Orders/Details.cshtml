@model Coffee.ViewModel.OrderDetailViewModel
@{
    Layout = "_ProductsCoffee";
    var totalQuantity = Model.Items.Sum(x => x.Quantity);
    var transactionId = string.IsNullOrWhiteSpace(Model.TransactionId) ? "Dang cap nhat" : Model.TransactionId;
}

@section Styles {
    <link rel="stylesheet" href="~/css/Orders/orders.css" />
}

<div class="orders-page container py-4 py-lg-5">
    @if (TempData["OrderSuccess"] != null)
    {
        <div class="alert alert-success mb-4">@TempData["OrderSuccess"]</div>
    }

    @if (TempData["OrderError"] != null)
    {
        <div class="alert alert-danger mb-4">@TempData["OrderError"]</div>
    }

    @if (TempData["MomoSuccess"] != null)
    {
        <div class="alert alert-success mb-4">@TempData["MomoSuccess"]</div>
    }

    <div class="orders-hero">
        <div>
            <div class="orders-eyebrow">Chi tiet don hang</div>
            <h3 class="mb-2">Don #@Model.OrderId</h3>
            <p class="text-muted mb-0">Theo doi giao hang, thanh toan va danh sach mon trong mot bo cuc gon hon.</p>
        </div>

        <a asp-controller="Orders" asp-action="Index" class="btn btn-outline-dark orders-hero-action">
            <i class="fas fa-arrow-left mr-2"></i>
            Quay lai lich su don
        </a>
    </div>

    <div class="row g-4 orders-detail-layout">
        <div class="col-lg-4">
            <aside class="order-summary-card">
                <div class="order-summary-header">
                    <span class="order-chip">Don #@Model.OrderId</span>
                    <span class="order-chip order-chip-soft">@totalQuantity mon</span>
                </div>

                <h5 class="mb-3">Thong tin giao hang</h5>

                <div class="order-summary-list">
                    <div class="order-summary-item">
                        <span>Nguoi nhan</span>
                        <strong>@Model.ReceiverName</strong>
                    </div>

                    <div class="order-summary-item">
                        <span>So dien thoai</span>
                        <strong>@Model.ReceiverPhone</strong>
                    </div>

                    <div class="order-summary-item">
                        <span>Dia chi</span>
                        <strong>@Model.ShippingAddress</strong>
                    </div>

                    <div class="order-summary-item">
                        <span>Ngay dat</span>
                        <strong>@Model.OrderDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</strong>
                    </div>

                    <div class="order-summary-item">
                        <span>Trang thai don</span>
                        <strong>@Model.Status</strong>
                    </div>

                    <div class="order-summary-item">
                        <span>Thanh toan</span>
                        <strong>@Model.PaymentStatus</strong>
                    </div>

                    <div class="order-summary-item">
                        <span>Phuong thuc</span>
                        <strong>@Model.PaymentMethod</strong>
                    </div>

                    <div class="order-summary-item">
                        <span>Ma giao dich</span>
                        <strong>@transactionId</strong>
                    </div>
                </div>

                <div class="order-total-card">
                    <span>Tong tien</span>
                    <strong>@Model.TotalAmount.ToString("N0") đ</strong>
                </div>

                @if (Model.CanCancel)
                {
                    <form asp-controller="Orders" asp-action="Cancel" method="post" class="mt-3">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.OrderId" />
                        <input type="hidden" name="redirectToDetails" value="true" />
                        <button type="submit"
                                class="btn btn-outline-danger btn-block"
                                onclick="return confirm('Ban chac chan muon huy don #@Model.OrderId?');">
                            Huy don nay
                        </button>
                    </form>
                }

                <div class="small text-muted mt-3">
                    @if (!string.IsNullOrWhiteSpace(Model.CustomerCancellationMessage))
                    {
                        <div class="mb-2">@Model.CustomerCancellationMessage</div>
                    }

                    @if (Model.IsCancelled)
                    {
                        <text>Don nay da duoc huy. He thong van giu lai lich su de ban doi chieu khi can.</text>
                    }
                    else if (Model.IsMomoPayment)
                    {
                        @if (Model.IsMomoPaid)
                        {
                            <text>Don MoMo nay da duoc he thong ghi nhan thanh toan. Shop se tiep tuc xu ly giao hang cho ban.</text>
                        }
                        else
                        {
                            <text>Don MoMo nay dang o trang thai chua thanh toan. Sau khi ban xac nhan chuyen tien hoac MoMo tra ket qua thanh cong, he thong se cap nhat sang da thanh toan.</text>
                        }
                    }
                    else
                    {
                        <text>Don COD bat dau o trang thai chua thanh toan. Khi admin duyet don, he thong se cap nhat sang da thanh toan.</text>
                    }
                </div>
            </aside>
        </div>

        <div class="col-lg-8">
            <section class="order-items-card">
                <div class="order-items-header">
                    <div>
                        <h5 class="mb-1">San pham trong don</h5>
                        <p class="mb-0 text-muted">Danh sach duoc gioi han chieu cao de don nhieu mon van gon mat.</p>
                    </div>

                    <span class="order-status-pill @(Model.IsCancelled ? "order-status-pill-danger" : null)">@Model.Status</span>
                </div>

                <div class="order-items-scroll">
                    @foreach (var item in Model.Items)
                    {
                        <div class="order-item-row">
                            <div class="order-item-main">
                                <div class="order-item-name">@item.ProductName</div>
                                <div class="order-item-meta">Don gia: @item.Price.ToString("N0") đ</div>
                            </div>

                            <div class="order-item-qty">x @item.Quantity</div>
                            <div class="order-item-subtotal">@item.SubTotal.ToString("N0") đ</div>
                        </div>
                    }
                </div>
            </section>
        </div>
    </div>
</div>
