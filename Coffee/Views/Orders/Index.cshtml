@model Coffee.ViewModel.OrderHistoryViewModel
@{
    Layout = "_ProductsCoffee";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="mb-1">Lich su don hang</h3>
            <div class="text-muted">Xem lai cac don hang COD ban da dat.</div>
        </div>

        <a asp-controller="Products" asp-action="Index" class="btn btn-outline-dark btn-sm">
            Tiep tuc mua sam
        </a>
    </div>

    @if (!Model.Orders.Any())
    {
        <div class="border rounded p-4 bg-white text-center">
            <h5 class="mb-2">Ban chua co don hang nao</h5>
            <div class="text-muted mb-3">Khi dat hang COD thanh cong, don hang se hien thi tai day.</div>
            <a asp-controller="Products" asp-action="Index" class="btn btn-dark">Mua ngay</a>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var order in Model.Orders)
            {
                <div class="col-12">
                    <div class="border rounded p-4 bg-white">
                        <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
                            <div>
                                <div class="fw-bold mb-1">Don #@order.OrderId</div>
                                <div class="text-muted small">Ngay dat: @order.OrderDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                                <div class="text-muted small">Nguoi nhan: @order.ReceiverName - @order.ReceiverPhone</div>
                                <div class="text-muted small">Dia chi: @order.ShippingAddress</div>
                                <div class="text-muted small">So luong san pham: @order.TotalItems</div>
                            </div>

                            <div class="text-end">
                                <div class="fw-bold text-danger mb-1">@order.TotalAmount.ToString("N0")</div>
                                <div class="small">Trang thai don: <span class="fw-bold">@order.Status</span></div>
                                <div class="small">Thanh toan: <span class="fw-bold">@order.PaymentStatus</span></div>
                                <div class="small">Phuong thuc: <span class="fw-bold">@order.PaymentMethod</span></div>
                            </div>
                        </div>

                        <div class="mt-3">
                            <a asp-controller="Orders" asp-action="Details" asp-route-id="@order.OrderId" class="btn btn-outline-dark btn-sm">
                                Xem chi tiet
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
