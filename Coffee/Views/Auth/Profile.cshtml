@model Coffee.DTO.UpdateProfileDTO

<div class="container py-5" style="max-width:600px;">
    <h3 class="text-center mb-4">Cap nhat thong tin nhan hang</h3>

    @if (ViewBag.Success != null)
    {
        <div class="alert alert-success">@ViewBag.Success</div>
    }

    <form method="post">
        <label class="form-label">Tai khoan</label>
        <input asp-for="Username" class="form-control mb-3" readonly />

        <label class="form-label">Email</label>
        <input asp-for="Email" class="form-control mb-3" readonly />

        <label class="form-label">So dien thoai</label>
        <input asp-for="Phone" class="form-control mb-1" placeholder="Nhap so dien thoai nhan hang" />
        <span asp-validation-for="Phone" class="text-danger"></span>

        <label class="form-label mt-3">Dia chi nhan hang</label>
        <textarea asp-for="Address"
                  class="form-control mb-1"
                  rows="4"
                  placeholder="So nha, duong, phuong/xa, quan/huyen, tinh/thanh pho"></textarea>
        <span asp-validation-for="Address" class="text-danger"></span>

        <button class="btn btn-dark w-100 mt-4">Luu thong tin</button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
