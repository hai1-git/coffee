@model Coffee.DTO.RegisterDTO

<div class="container py-5" style="max-width:500px;">
    <h3 class="text-center mb-4">Đăng ký</h3>

    <form method="post">

        <input asp-for="Username" class="form-control mb-1" placeholder="Username" />
        <span asp-validation-for="Username" class="text-danger"></span>

        <input asp-for="Email" class="form-control mb-1" placeholder="Email" />
        <span asp-validation-for="Email" class="text-danger"></span>

        <input asp-for="Password" type="password" class="form-control mb-1" placeholder="Password" />
        <span asp-validation-for="Password" class="text-danger"></span>

        <input asp-for="ConfirmPassword" type="password" class="form-control mb-1" placeholder="Nhập lại Password" />
        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>

        <button class="btn btn-dark w-100 mt-3">Đăng ký</button>

    </form>

    <div class="text-center mt-3">
        <a href="/Auth/Login">Đã có tài khoản?</a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}