@model Coffee.DTO.ChangePasswordDTO

@{
    ViewData["Title"] = "Đổi mật khẩu";
    Layout = "_HomeCoffee";
}

<section class="container py-5">
    <div class="mx-auto" style="max-width: 620px;">
        <div class="bg-white shadow-sm rounded-4 p-4 p-lg-5 border">
            <div class="text-center mb-4">
                <h2 class="mb-2">Doi mat khau</h2>
                <p class="text-muted mb-0">Cap nhat mat khau moi de tai khoan an toan hon.</p>
            </div>

            @if (ViewBag.Success != null)
            {
                <div class="alert alert-success">
                    @ViewBag.Success
                </div>
            }

            <form asp-action="ChangePassword" method="post">
                <div class="mb-3">
                    <label asp-for="OldPassword" class="form-label">Mat khau cu</label>
                    <input asp-for="OldPassword" type="password" class="form-control" />
                    <span asp-validation-for="OldPassword" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="NewPassword" class="form-label">Mat khau moi</label>
                    <input asp-for="NewPassword" type="password" class="form-control" />
                    <span asp-validation-for="NewPassword" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label">Xac nhan mat khau</label>
                    <input asp-for="ConfirmPassword" type="password" class="form-control" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

                <button class="btn btn-dark w-100">Luu mat khau moi</button>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
