@model Coffee.DTO.ResetPasswordDTO

<div class="container py-5" style="max-width:560px;">
    <h3 class="text-center mb-4">Dat lai mat khau</h3>

    @if (TempData["ResetPasswordInfo"] != null)
    {
        <div class="alert alert-success">@TempData["ResetPasswordInfo"]</div>
    }

    <div class="alert alert-secondary">
        Mo Gmail de lay ma xac nhan 6 so. Ma co hieu luc trong 10 phut.
    </div>

    <form method="post">
        <label class="form-label">Gmail dang ky</label>
        <input asp-for="Email" class="form-control mb-1" placeholder="example@gmail.com" />
        <span asp-validation-for="Email" class="text-danger"></span>

        <label class="form-label mt-3">Ma xac nhan</label>
        <input asp-for="VerificationCode" class="form-control mb-1" placeholder="Nhap 6 chu so" />
        <span asp-validation-for="VerificationCode" class="text-danger"></span>

        <label class="form-label mt-3">Mat khau moi</label>
        <input asp-for="NewPassword" type="password" class="form-control mb-1" placeholder="Nhap mat khau moi" />
        <span asp-validation-for="NewPassword" class="text-danger"></span>

        <label class="form-label mt-3">Nhap lai mat khau moi</label>
        <input asp-for="ConfirmPassword" type="password" class="form-control mb-1" placeholder="Nhap lai mat khau moi" />
        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>

        <div asp-validation-summary="ModelOnly" class="text-danger mt-3"></div>

        <button class="btn btn-dark w-100 mt-4">Dat lai mat khau</button>
    </form>

    <div class="text-center mt-3">
        <a href="/Auth/Login">Quay lai dang nhap</a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
