@model Coffee.DTO.ForgotPasswordDTO

<div class="container py-5" style="max-width:520px;">
    <h3 class="text-center mb-4">Quen mat khau</h3>

    <div class="alert alert-info">
        Nhap Gmail da dang ky. He thong se gui ma xac nhan 6 so de ban dat lai mat khau.
    </div>

    <form method="post">
        <label class="form-label">Gmail dang ky</label>
        <input asp-for="Email" class="form-control mb-1" placeholder="example@gmail.com" />
        <span asp-validation-for="Email" class="text-danger"></span>

        <div asp-validation-summary="ModelOnly" class="text-danger mt-3"></div>

        <button class="btn btn-dark w-100 mt-3">Gui ma xac nhan</button>
    </form>

    <div class="text-center mt-3">
        <a href="/Auth/Login">Quay lai dang nhap</a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
