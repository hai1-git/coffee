@model Coffee.DTO.LoginDTO

<div class="container py-5" style="max-width:500px;">
    <h3 class="text-center mb-4">Đăng nhập</h3>

    <form method="post">

        <input asp-for="Username" class="form-control mb-1" placeholder="Username" />
        <span asp-validation-for="Username" class="text-danger"></span>

        <input asp-for="Password" type="password" class="form-control mb-1" placeholder="Password" />
        <span asp-validation-for="Password" class="text-danger"></span>

        <div asp-validation-summary="All" class="text-danger"></div>

        <button class="btn btn-dark w-100 mt-3">Đăng nhập</button>

    </form>

    <div class="text-center mt-3">
        <a href="/Auth/Register">Chưa có tài khoản?</a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}