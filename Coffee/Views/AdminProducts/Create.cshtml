@model Coffee.Models.Product

@{
    ViewData["Title"] = "Create";
    Layout = "_ProductsCoffee";
}

<h2 class="mb-4">➕ Thêm sản phẩm</h2>

<div class="row">
    <div class="col-md-5">
        <form asp-action="Create" enctype="multipart/form-data" class="card p-4 shadow">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <!-- TÊN -->
            <div class="mb-3">
                <label asp-for="ProductName" class="form-label"></label>
                <input asp-for="ProductName" class="form-control" />
            </div>

            <!-- GIÁ -->
            <div class="mb-3">
                <label asp-for="Price" class="form-label"></label>
                <input asp-for="Price" class="form-control" />
            </div>

            <!-- MÔ TẢ -->
            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <input asp-for="Description" class="form-control" />
            </div>

            <!-- 🔥 UPLOAD XỊN -->
            <div class="mb-3">
                <label class="form-label">Ảnh sản phẩm</label>

                <div id="dropArea" class="border rounded p-3 text-center" style="cursor:pointer;">
                    <p class="text-muted m-0">Kéo thả ảnh vào đây hoặc click để chọn</p>
                    <input type="file" name="file" id="fileInput" hidden accept="image/*" />
                </div>

                <!-- PREVIEW -->
                <div class="mt-3 text-center">
                    <img id="preview" src=""
                         style="max-width:150px; display:none; border-radius:10px;" />
                </div>
            </div>

            <!-- DANH MỤC -->
            <div class="mb-3">
                <label asp-for="CategoryId" class="form-label"></label>
                <select asp-for="CategoryId" class="form-control"
                        asp-items="ViewBag.CategoryId"></select>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success w-100">Tạo</button>
                <a asp-action="Index" class="btn btn-secondary w-100">Quay lại</a>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    <script>
        const dropArea = document.getElementById("dropArea");
        const fileInput = document.getElementById("fileInput");
        const preview = document.getElementById("preview");

        // 👉 click để chọn file
        dropArea.addEventListener("click", () => fileInput.click());

        // 👉 chọn file
        fileInput.addEventListener("change", function () {
            showPreview(this.files[0]);
        });

        // 👉 drag & drop
        dropArea.addEventListener("dragover", (e) => {
            e.preventDefault();
            dropArea.classList.add("bg-light");
        });

        dropArea.addEventListener("dragleave", () => {
            dropArea.classList.remove("bg-light");
        });

        dropArea.addEventListener("drop", (e) => {
            e.preventDefault();
            dropArea.classList.remove("bg-light");

            const file = e.dataTransfer.files[0];
            fileInput.files = e.dataTransfer.files;

            showPreview(file);
        });

        // 👉 preview ảnh
        function showPreview(file) {
            if (!file) return;

            const url = URL.createObjectURL(file);
            preview.src = url;
            preview.style.display = "block";
        }
    </script>
}