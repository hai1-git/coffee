@model Coffee.Models.Category

@{
    ViewData["Title"] = "Xoa category";
    Layout = "_ProductsCoffee";
    var productCount = Model.Products?.Count ?? 0;
    var canDelete = productCount == 0;
    var description = string.IsNullOrWhiteSpace(Model.Description)
        ? "Chua co mo ta cho category nay."
        : Model.Description.Trim();
}

@section Styles {
    <link rel="stylesheet" href="~/css/Admin/admin-category.css" />
}

<div class="admin-category-shell container py-4 py-lg-5">
    <section class="admin-category-hero admin-category-hero-compact">
        <div>
            <span class="admin-category-eyebrow">Delete category</span>
            <h1>Xoa category</h1>
            <p>Kiem tra lai category truoc khi xoa de tranh mat lien ket voi san pham hoac gay xao tron cau truc menu.</p>
        </div>

        <div class="admin-category-hero-actions">
            <a asp-action="Details" asp-route-id="@Model.CategoryId" class="admin-ghost-button">
                <i class="fas fa-eye"></i>
                <span>Xem chi tiet</span>
            </a>
            <a asp-action="Index" class="admin-secondary-button">
                <i class="fas fa-list"></i>
                <span>Ve danh sach</span>
            </a>
        </div>
    </section>

    <section class="admin-category-detail-grid">
        <article class="admin-category-warning-card @(canDelete ? "is-safe" : null)">
            <div>
                <span class="admin-category-eyebrow">Safety check</span>
                <h3>@(canDelete ? "Category da san sang de xoa" : "Category nay chua the xoa")</h3>
                <p>
                    @(canDelete
                        ? "Khong co san pham nao dang gan category nay, ban co the xoa neu chac chan khong can dung nua."
                        : "Category nay van con san pham dang su dung. Hay chuyen san pham sang category khac truoc khi xoa.")
                </p>
            </div>

            <div class="admin-category-side-list">
                <div class="admin-category-side-item">
                    <strong>So san pham dang gan</strong>
                    <p>@productCount san pham</p>
                </div>
                <div class="admin-category-side-item">
                    <strong>Luu y</strong>
                    <p>Xoa category la thao tac khong nen thuc hien khi du lieu van dang duoc dung trong he thong.</p>
                </div>
            </div>

            <form asp-action="Delete">
                <input type="hidden" asp-for="CategoryId" />
                <div class="admin-category-form-actions">
                    <a asp-action="Index" class="admin-secondary-button">
                        <i class="fas fa-arrow-left"></i>
                        <span>Quay lai</span>
                    </a>
                    @if (canDelete)
                    {
                        <button type="submit" class="admin-danger-button">
                            <i class="fas fa-trash-alt"></i>
                            <span>Xac nhan xoa category</span>
                        </button>
                    }
                    else
                    {
                        <button type="button" class="admin-danger-button disabled" disabled>
                            <i class="fas fa-ban"></i>
                            <span>Chua the xoa category</span>
                        </button>
                    }
                </div>
            </form>
        </article>

        <aside class="admin-category-detail-card">
            <div class="admin-category-detail-meta">
                <span class="admin-category-pill is-dark">
                    <i class="fas fa-hashtag"></i>
                    <span>ID #@Model.CategoryId</span>
                </span>
                <span class="admin-category-pill">
                    <i class="fas fa-box-open"></i>
                    <span>@productCount san pham</span>
                </span>
            </div>

            <h3>Thong tin se bi anh huong</h3>

            <dl>
                <dt>Ten category</dt>
                <dd>@(string.IsNullOrWhiteSpace(Model.CategoryName) ? "Chua co ten" : Model.CategoryName)</dd>

                <dt>Mo ta</dt>
                <dd>@description</dd>
            </dl>
        </aside>
    </section>
</div>
